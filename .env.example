# Directory containing bridge_latest.csv + dated bridge CSVs
BRIDGE_DIR=/Users/josephstorey/Market_Analyse/reports

# Account-trust backtest CSV (generated by the daily pipeline's backtest step; may not exist until the first scheduled run)
ACCOUNTS_CSV=/Users/josephstorey/Market_Review/reports/account_backtest.csv
