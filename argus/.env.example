# --- IBKR ---
# Run TWS or IB Gateway, enable API in Configure -> API -> Settings.
# Default ports: TWS Live=7496, TWS Paper=7497, Gateway Live=4001, Gateway Paper=4002.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=11
# Set to 1 to allow live trading from /api/execute. Off by default for safety.
IBKR_LIVE_TRADING=0

# --- Anthropic (optional, for Chart Chat & AI Analysis) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Alerts ---
# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=

# Telegram (create bot via @BotFather, get chat id by messaging the bot then hitting getUpdates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Generic webhook (HMAC-signed)
WEBHOOK_URL=
WEBHOOK_SECRET=

# --- Server ---
ARGUS_HOST=127.0.0.1
ARGUS_PORT=8088
# Optional: set to a random string to require X-Argus-Token header on state-changing API calls
ARGUS_API_TOKEN=
